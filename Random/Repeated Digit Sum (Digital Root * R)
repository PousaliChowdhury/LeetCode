def repeated_digit_sum(N, R):
    if R == 0:
        return 0
    
    total_sum = 0
    
    for d in str(N):
        total_sum += int(d)
    
    total = total_sum * R
    
    if total == 0:
        return 0
    
    return 1 + (total - 1) % 9


if __name__ == "__main__":
    N = input().strip()
    R = int(input().strip())
    
    print(repeated_digit_sum(N,R))
