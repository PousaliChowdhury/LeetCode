def count_sundays(start_day, n):
    days = ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
    start_index = days.index(start_day.lower())
    
    count = 0
    for i in range(n):
        if (start_index + i) % 7 == 6:
            count += 1
    
    return count

if __name__ == "__main__":
    start_day = input().strip()
    n = int(input().strip())

    print(count_sundays(start_day, n))
