def count_leaders(arr):
    max_so_far = float('-inf')
    count = 0
    
    for num in arr:
        if num > max_so_far:
            count += 1
            max_so_far = num
    
    return count
    
if __name__ == "__main__":
    n = int(input().strip())
    arr = list(map(int, input().split()))

    print(count_leaders(arr))
